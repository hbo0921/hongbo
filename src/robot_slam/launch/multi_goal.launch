<launch>
  <!-- 
    此 launch 文件用于启动 user.py，使用以下点位坐标
    点位使用说明：
    - goals[1]: 计算题识别位置（第1259行）
    - goals[3,4,5]: 第一面墙的三个识别点
    - goals[6,7,8]: 第二面墙的三个识别点
    - goals[9,10,11]: 第三面墙的三个识别点
    - goals[13]: 进点（第1328行）
    - goals[14]: 终点（第1341行）
  -->
  <node name="navigation_demo" pkg="robot_slam" type="user.py" output="screen">
      <!-- X坐标列表（共18个点，索引0-17，user.py需要至少15个点）-->
      <param name="goalListX" value="0, 0.423, 1.587, 2.809, 2.929, 2.954, 3.144, 2.993, 1.785, 0.535, 0.334, 0.300, 0.178, 2.248, 2.398, 0.988, 1.106, 1.671"/>
      <!-- Y坐标列表（共18个点）-->
      <param name="goalListY" value="0, -0.253, -0.220, -0.136, -0.241, -1.473, -2.677, -2.803, -2.909, -3.046, -2.920, -1.670, -0.425, -0.842, -2.083, -0.978, -2.241, -1.566"/>
      <!-- 航向角列表（共18个点，单位：度）-->
      <param name="goalListYaw" value="0, 90, 90, 90, 0, 0, 0, -90, -90, -90, 180, 180, 180, -90, 90, -90, 90, 0"/>
  </node>
</launch>

